{
  "name": "ai-reviewer",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "review": "bun src/index.ts",
    "review:local": "bun src/local.ts",
    "lint": "eslint --flag unstable_native_nodejs_ts_config src/ github/",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@github/copilot-sdk": "latest",
    "@octokit/rest": "^20.1.1",
    "probot": "^14.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^20.14.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "smee-client": "^5.0.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix --flag unstable_native_nodejs_ts_config",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged",
    "pre-push": "bun run typecheck"
  }
}
